{
  "name": "skynot",
  "version": "0.0.2",
  "description": "Quick NPX tool to set up a pi user and install the pi-coding-agent",
  "main": "dist/index.js",
  "bin": {
    "skynot": "dist/index.js"
  },
  "scripts": {
    "build": "npx tsc",
    "prepublishOnly": "npm run build",
    "run": "npm install && npm run build && node dist/index.js"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "ai",
    "llm",
    "cli",
    "tui",
    "agent",
    "installer"
  ],
  "author": "Andres G. Aragoneses",
  "license": "AGPL",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nblockchain/skynot.git"
  },
  "bugs": {
    "url": "https://github.com/nblockchain/skynot/issues"
  },
  "homepage": "https://github.com/nblockchain/skynot#readme",
  "dependencies": {
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.3.3"
  }
}
